{
  "name": "@goldnight/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "build:render": "pnpm --filter @goldnight/config build && pnpm --filter @goldnight/types build && prisma generate && tsc -p tsconfig.json",
    "start:render": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@goldnight/config": "workspace:*",
    "@goldnight/types": "workspace:*",
    "@prisma/client": "^6.5.0",
    "@supabase/supabase-js": "^2.102.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3"
  }
}
