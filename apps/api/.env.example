NODE_ENV=development
PORT=3000

# Local Prisma (optional; production often uses Supabase only)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goldnight_vpn?schema=public

# --- Data layer ---
DATA_LAYER=supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- VPN: 3x-ui / Xray ---
# When using panel API, set VPN_PROVIDER=xui and fill XUI_* (see apps/api/README.md).
VPN_PROVIDER=xui

# Origin + path prefix where the panel is mounted (no trailing slash).
# Code builds: {XUI_HOST}{XUI_BASE_PATH}/login and .../panel/api/...
# Either put the full prefix in XUI_HOST and leave XUI_BASE_PATH empty (example below),
# or XUI_HOST=https://host:port and XUI_BASE_PATH=/your/panel/prefix
# Example only — use your real panel URL locally / in secrets; do not commit production hosts.
XUI_HOST=https://panel.example.com:PORT/your-admin-prefix
XUI_BASE_PATH=

# Panel credentials — set locally / in Render; do not commit real values.
XUI_USER=
XUI_PASS=

XUI_INBOUND_ID=1
XUI_DOMAIN=vpn.example.com
XUI_PORT=443
# Для TCP+XTLS (Vision) оставьте flow и type=tcp в EXTRA_QUERY. Для XHTTP+TLS flow не нужен — не задавайте XUI_VLESS_FLOW.
# XUI_VLESS_FLOW=xtls-rprx-vision
# Доп. query для vless:// — скопируйте из «Поделиться» / экспорта 3x-ui для ЭТОГО inbound (должно совпадать с панелью).
# Пример XHTTP+TLS (подставьте свой sni/host):
XUI_VLESS_EXTRA_QUERY=type=xhttp&mode=packet-up&security=tls&path=%2F&fp=chrome&alpn=h2%2Chttp%2F1.1&sni=vpn.example.com
# Старый пример TCP+TLS (если inbound именно TCP):
# XUI_VLESS_FLOW=xtls-rprx-vision
# XUI_VLESS_EXTRA_QUERY=type=tcp&security=tls&fp=chrome&alpn=http%2F1.1&sni=vpn.example.com
# 3x-ui per-client limitIp (distinct source IPs per VLESS UUID). Default in code is 1; set 0 to disable.
# XUI_CLIENT_LIMIT_IP=1

# --- Telegram / auth ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_URL=http://localhost:5173
# Optional: subscription expiry reminder scan interval (ms). Default 6 hours.
# SUBSCRIPTION_REMINDER_INTERVAL_MS=21600000
# Optional: mark overdue subs expired + revoke VPN sweep (ms). Default 10 minutes.
# SUBSCRIPTION_EXPIRY_SWEEP_INTERVAL_MS=600000
AUTH_JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_HEX_OR_STRING
AUTH_TOKEN_TTL_SECONDS=604800
TELEGRAM_INITDATA_TTL_SECONDS=86400

# --- Service keys ---
ADMIN_API_KEY=
BOT_API_KEY=

# --- YooKassa (optional; both shop id + secret required for checkout) ---
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# YOOKASSA_RETURN_URL=https://your-mini-app.example/plans
# YOOKASSA_WEBHOOK_SECRET=
# Optional: receipt VAT code for YooKassa (1–6). Default in code is 1 (без НДС).
# YOOKASSA_RECEIPT_VAT_CODE=1
